# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Environment files (contain secrets — never commit) ────────
# Keep `.env.example` as a checked-in template; ignore everything else.
.env
.env.*
!.env.example

# ── Build / distribution artifacts ────────────────────────────
build/
dist/
out/
deploy/

# ── Archives (zipped builds, snapshots) ───────────────────────
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Local caches / tooling ────────────────────────────────────
.cache/
.parcel-cache/
.vite/
.eslintcache
.tsbuildinfo
*.tsbuildinfo
coverage/

# ── OS / editor cruft ─────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# ── Runtime artifacts (not source) ────────────────────────────
uploads/
.claude/
