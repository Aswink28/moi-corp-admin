# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Environment files ─────────────────────────────────────────
# Single `.env` per app (mirror of the frontend). The committed `.env` holds
# development values; on a server you edit its values for that environment.
# No per-environment files; real production secrets are filled in on the server.
.env.*.local
*.secrets

# ── Build / distribution artifacts ────────────────────────────
build/
dist/
out/
deploy/

# ── Archives (zipped builds, snapshots) ───────────────────────
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Local caches / tooling ────────────────────────────────────
.cache/
.parcel-cache/
.vite/
.eslintcache
.tsbuildinfo
*.tsbuildinfo
coverage/

# ── OS / editor cruft ─────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# ── Runtime artifacts (not source) ────────────────────────────
uploads/
.claude/
