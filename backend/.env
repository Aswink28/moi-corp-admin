NODE_ENV=development
PORT=6010

PGHOST=localhost
PGPORT=5432
PGDATABASE=company_admin_db
PGUSER=postgres
PGPASSWORD=test@1234
DATABASE_URL=

JWT_SECRET=dev-company-admin-secret-please-change-in-prod-7f3a9
JWT_EXPIRES_IN=12h

CORS_ORIGINS=http://localhost:5180

# Moi-Corp Product (TravelDesk) integration. PRODUCT_PROVISIONING_SECRET must
# match PROVISIONING_SECRET in the Product backend .env.
PRODUCT_API_URL=http://localhost:5015
PRODUCT_PROVISIONING_SECRET=__FILL_IN__
# Timeout (ms) for live Dashboard/Company-Analytics fetches from Product.
PRODUCT_ANALYTICS_TIMEOUT_MS=8000

SEED_SUPERADMIN_NAME=Super Admin
SEED_SUPERADMIN_EMAIL=superadmin@company-admin.local
SEED_SUPERADMIN_PASSWORD=__FILL_IN__

# SMTP / mailer (leave SMTP_HOST blank to log emails to the console in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@company-admin.local

# Uploads (logos, etc.) — defaults to <backend>/uploads when blank
UPLOAD_DIR=

# Public base URL of this service (used to build absolute links in emails)
APP_PUBLIC_URL=http://localhost:6010
