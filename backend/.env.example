# ── Company Admin Portal — Backend env ──────────────────────────
# This service is COMPLETELY independent from the Travel Expense app.

NODE_ENV=development
PORT=6010

# Separate PostgreSQL database (NOT the travel app's traveldesk_db)
PGHOST=localhost
PGPORT=5432
PGDATABASE=company_admin_db
PGUSER=postgres
PGPASSWORD=postgres
# Optional single connection string (overrides the individual PG* vars if set)
DATABASE_URL=

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5180

# Seed super admin (used by `npm run seed`)
SEED_SUPERADMIN_NAME=Super Admin
SEED_SUPERADMIN_EMAIL=superadmin@company-admin.local
SEED_SUPERADMIN_PASSWORD=Admin@12345

# SMTP / mailer — leave SMTP_HOST blank to log the full email to the console (dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@company-admin.local

# Uploads (logos, etc.) — defaults to <backend>/uploads when blank
UPLOAD_DIR=

# Public base URL of this service (used to build absolute links in emails)
APP_PUBLIC_URL=http://localhost:6010

# ── Moi-Corp Product (TravelDesk) integration ──────────────────
# The Product backend base URL. Used for BOTH provisioning and the live
# Dashboard/Company-Analytics data feed (no value is hardcoded in code).
PRODUCT_API_URL=http://localhost:5015
# Shared secret for the Product internal APIs (provisioning + analytics).
# MUST match PROVISIONING_SECRET in the Product backend .env.
PRODUCT_PROVISIONING_SECRET=__FILL_IN__
# Timeout (ms) for live analytics fetches from Product.
PRODUCT_ANALYTICS_TIMEOUT_MS=8000
