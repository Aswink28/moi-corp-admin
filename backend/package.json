{
  "name": "company-admin-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Company Onboarding Admin Portal — backend API (independent from the Travel Expense Management app)",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "seed:users": "node src/db/seedUsers.js",
    "db:setup": "node src/db/migrate.js && node src/db/seed.js"
