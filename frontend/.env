# ── Company Admin Portal — frontend configuration (single .env file) ─────────
# This is the ONLY frontend env file. Vite loads it at build time.
# Base URL of the company-admin backend API. Use "/api" to call the backend
# same-origin (a reverse proxy routes /api → backend). Set an absolute URL
# (e.g. http://192.168.x.x:6010/api) to point at a backend on another host.
VITE_API_BASE_URL=/api

# Public subpath the app is served from. All admin URLs are prefixed with this,
# e.g. /moi-corp-admin/companies. Must start AND end with a slash.
VITE_BASE=/moi-corp-admin/
